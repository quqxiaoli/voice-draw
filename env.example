# 复制为 .env 后填入真实值。.env 已在 .gitignore,绝不提交。
# 缺任一变量时后端启动应直接报错并提示来这里配。

# LLM 接入(OpenAI 兼容协议,D5/D12)
# LLM_BASE_URL 约定:可填带或不带 /v1 后缀两种写法,客户端会智能拼接 /chat/completions。
#   例:https://api.deepseek.com 或 https://api.deepseek.com/v1 均可
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# 服务端口
PORT=8080

# 前端访问后端的地址(部署时改为服务器公网地址,如 http://1.2.3.4:8080)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# 议题需要才启用 ↓
# ASR_API_KEY=
